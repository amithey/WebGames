# ── Supabase (backend + storage) ─────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>

# Direct PostgreSQL connection string (used by the pg driver)
# Found in: Supabase Dashboard → Project Settings → Database → Connection string (URI)
# Append ?sslmode=require if not already present
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── CORS (backend) ────────────────────────────────────────────────────────────
# Set to your Vercel frontend URL in production (e.g. https://webgames.vercel.app)
FRONTEND_URL=https://<your-frontend>.vercel.app

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Set to your Vercel backend URL in production (e.g. https://webgames-api.vercel.app)
# Leave empty for local development (Vite proxy handles it)
VITE_API_URL=https://<your-backend>.vercel.app
